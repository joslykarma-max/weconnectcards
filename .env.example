# ─────────────────────────────────────────────────────────────────
# We Connect Cards — Environment Variables
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://weconnect.cards
NEXT_PUBLIC_URL=https://weconnect.cards

# ── Firebase Admin SDK (server-side) ─────────────────────────────
# Found in Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
# Paste the private key as-is (with literal \n for line breaks, no surrounding quotes)
FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"

# ── Firebase Client SDK (browser-side) ───────────────────────────
# Found in Firebase Console → Project Settings → Your apps → Web app config
NEXT_PUBLIC_FIREBASE_API_KEY=AIza...
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:abc123

# ── FedaPay (payments) ───────────────────────────────────────────
# sandbox: from https://sandbox.fedapay.com → Settings → API Keys
# production: from https://app.fedapay.com → Settings → API Keys
FEDAPAY_SECRET_KEY=sk_live_...
# Set to "sandbox" for test/preview, "production" for live payments
FEDAPAY_ENV=sandbox

# ── Admin access ─────────────────────────────────────────────────
# Firebase UIDs allowed to access /admin (comma-separated)
# Get a UID from Firebase Console → Authentication → Users
ADMIN_UIDS=uid1,uid2

# ── Email (optional — invitations équipe) ────────────────────────
# From https://account.postmarkapp.com → Servers → API Tokens
POSTMARK_SERVER_TOKEN=
