rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────
    function isAuthed() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return isAuthed() && request.auth.uid == uid;
    }
    function isAdmin() {
      return isAuthed() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // ── Users ─────────────────────────────────────────────────────
    // Only the owner or admin can read/write their user doc
    match /users/{uid} {
      allow read:   if isOwner(uid) || isAdmin();
      allow write:  if isAdmin(); // writes via Admin SDK only
    }

    // ── Profiles ─────────────────────────────────────────────────
    // Public profiles readable by anyone; writable only by owner (via API)
    match /profiles/{uid} {
      allow read:   if true;
      allow write:  if isAdmin();

      match /links/{linkId} {
        allow read:   if true;
        allow write:  if isAdmin();
      }
    }

    // ── Usernames ─────────────────────────────────────────────────
    match /usernames/{username} {
      allow read:   if true;
      allow write:  if isAdmin();
    }

    // ── Cards ─────────────────────────────────────────────────────
    match /cards/{cardId} {
      allow read:  if isOwner(resource.data.userId) || isAdmin();
      allow write: if isAdmin();
    }

    // ── Scans / Clicks / Contacts ────────────────────────────────
    // Write via Admin SDK only; owner can read their own
    match /scans/{id} {
      allow read:  if isOwner(resource.data.userId) || isAdmin();
      allow write: if isAdmin();
    }
    match /linkClicks/{id} {
      allow read:  if isOwner(resource.data.profileId) || isAdmin();
      allow write: if isAdmin();
    }
    match /savedContacts/{id} {
      allow read:  if isOwner(resource.data.profileId) || isAdmin();
      allow write: if isAdmin();
    }

    // ── Modules ───────────────────────────────────────────────────
    match /modules/{moduleId} {
      allow read:   if true; // needed for public profile
      allow write:  if isAdmin();
    }

    // ── Teams ─────────────────────────────────────────────────────
    match /teams/{ownerId} {
      allow read:   if isOwner(ownerId) || isAdmin();
      allow write:  if isAdmin();

      match /members/{email} {
        allow read:   if isOwner(ownerId) || isAdmin();
        allow write:  if isAdmin();
      }
    }

    // ── Payments ──────────────────────────────────────────────────
    match /payments/{id} {
      allow read:  if isOwner(resource.data.uid) || isAdmin();
      allow write: if isAdmin();
    }

    // ── Pending orders ────────────────────────────────────────────
    match /pendingOrders/{uid} {
      allow read:  if isOwner(uid) || isAdmin();
      allow write: if isAdmin();
    }

    // ── Admins ────────────────────────────────────────────────────
    match /admins/{uid} {
      allow read:  if isAuthed();
      allow write: if isAdmin();
    }

    // ── Deny all other reads/writes ───────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
