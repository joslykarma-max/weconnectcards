generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  password      String?
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  profile       Profile?
  subscription  Subscription?
  cards         Card[]
  scansReceived Scan[]         @relation("ScansReceived")
  team          TeamMember[]

  // NextAuth
  accounts      Account[]
  sessions      Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Profile {
  id          String  @id @default(cuid())
  userId      String  @unique
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  username    String  @unique
  displayName String
  title       String?
  company     String?
  bio         String?
  avatar      String?
  theme       String  @default("midnight")

  links        Link[]
  modules      ModuleConfig[]
  savedBy      SavedContact[]

  isPublic  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Link {
  id        String  @id @default(cuid())
  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  type     String
  label    String
  url      String
  icon     String?
  order    Int     @default(0)
  isActive Boolean @default(true)

  clicks    LinkClick[]
  createdAt DateTime    @default(now())
}

model LinkClick {
  id        String   @id @default(cuid())
  linkId    String
  link      Link     @relation(fields: [linkId], references: [id], onDelete: Cascade)
  clickedAt DateTime @default(now())
  device    String?
  country   String?
}

model Scan {
  id     String @id @default(cuid())
  userId String
  user   User   @relation("ScansReceived", fields: [userId], references: [id], onDelete: Cascade)

  device    String?
  country   String?
  city      String?
  userAgent String?
  scannedAt DateTime @default(now())
}

model SavedContact {
  id        String   @id @default(cuid())
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  savedAt   DateTime @default(now())
  device    String?
}

model Card {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  edition     String   @default("midnight")
  nfcId       String?  @unique
  status      String   @default("pending")
  orderedAt   DateTime @default(now())
  activatedAt DateTime?
}

model Subscription {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  plan      String  @default("essentiel")
  status    String  @default("active")
  fedapayId String?

  currentPeriodEnd DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model ModuleConfig {
  id        String  @id @default(cuid())
  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  type     String
  isActive Boolean @default(false)
  config   Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([profileId, type])
}

model TeamMember {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  teamOwnerId String
  role        String   @default("member")
  joinedAt    DateTime @default(now())
}
